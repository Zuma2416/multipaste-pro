{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MultiPaste Pro",
  "version": "0.1.0",
  "identifier": "com.amatuhi.multipaste-pro",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "url": "index.html",
        "title": "MultiPaste Pro",
        "width": 800,
        "height": 600,
        "visible": false
      },
      {
        "label": "hud",
        "url": "index.html?view=hud",
        "title": "",
        "width": 440,
        "height": 80,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false
      },
      {
        "label": "picker",
        "url": "index.html?view=picker",
        "title": "",
        "width": 500,
        "height": 520,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Zuma2416/multipaste-pro/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI1MkYzNTIzNjYyNUVCRApSV1M5WG1JMlV2TlNDNVBkQWpKaDUvSjhRcWJsODNlR0ZyYldVNThTSVg1NTBITjVYVmF4alFiSgo="
    }
  }
}
